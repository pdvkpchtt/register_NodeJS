# Скопируйте в .env и подставьте значения.
# На Timeweb: переменные задаются в панели приложения.

DATABASE_URL="file:./dev.db"
PORT="4001"

# Один или несколько origin фронта (через запятую, без пробелов или с пробелами — обрежутся).
# Пример продакшена Vite на Timeweb:
# FRONT_ORIGIN="https://ваш-поддомен.twc1.net"
FRONT_ORIGIN="http://localhost:5173"

# Дополнительные origin (если удобнее вынести отдельно), тоже через запятую:
# CORS_ORIGINS="https://site-a.net,https://site-b.net"

# Опционально: публичный URL API для лога при старте (полный https://...)
# PUBLIC_URL="https://ваш-api.twc1.net"
